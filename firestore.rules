rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções helper ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isAdmin() {
      return request.auth.token.role == 'admin';
    }
    function isManager() {
      return request.auth.token.role == 'manager'
          || request.auth.token.role == 'admin';
    }
    function clientCannotElevateBiometric() {
      let d = request.resource.data;
      return d.biometricVerified == false
          && d.processingStatus == 'pending'
          && d.photoURL == null
          && d.aiValidation == null;
    }
    function hasRequiredPontoFields() {
      let d = request.resource.data;
      return d.keys().hasAll([
        'userId','type','timestamp','isManual',
        'biometricVerified','processingStatus'
      ]);
    }
    function isValidPontoType() {
      return request.resource.data.type in [
        'entry','lunch_start','lunch_end','exit'
      ];
    }

    // ── Apresentações: leitura pública (link de cliente sem auth) ──
    match /presentations/{presentationId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── Orçamentos Públicos: leitura pública (/orcamentos/:id) ──
    match /os_orcamentos/{orcamentoId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── Registro de Ponto ─────────────────────────────────────────────────
    match /timeEntries/{entryId} {
      allow read: if isAuthenticated()
        && (isOwner(resource.data.userId) || isManager());
      // Colaborador criando seu próprio ponto
      allow create: if isAuthenticated()
        && (
          // Próprio colaborador
          (isOwner(request.resource.data.userId)
            && hasRequiredPontoFields()
            && isValidPontoType()
            && clientCannotElevateBiometric())
          ||
          // Gestor/Admin fazendo correção manual para outro colaborador
          (isManager()
            && hasRequiredPontoFields()
            && isValidPontoType())
        );
      allow update: if isAuthenticated()
        && (
          // Próprio ponto: atualização restrita a campos de processamento
          (isOwner(resource.data.userId)
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['photoURL', 'aiValidation',
                         'biometricVerified', 'processingStatus']))
          ||
          // Gestor/Admin: pode editar qualquer campo
          isManager()
        );
      allow delete: if isAdmin();
    }

    // ── Locais de Trabalho ────────────────────────────────────────────────
    match /workLocations/{locationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Usuários ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated()
        && (isOwner(userId) || isManager());
      allow write: if isAuthenticated()
        && (isOwner(userId) || isAdmin());
    }

    // ── Tarefas / OS ──────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuthenticated()
        && (resource.data.assignedTo == request.auth.uid || isManager());
      allow write: if isManager();
    }

    // ══════════════════════════════════════════════════════════════════════
    // MÓDULO DE PROJETOS V2 — SECURITY RULES
    // ══════════════════════════════════════════════════════════════════════

    // ── Leads: criação pública com validação (formulário anúncios) ──
    match /project_leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll([
          'nomeContato', 'telefone', 'tipoProjetoSlug', 'criadoEm', 'status'
        ])
        && request.resource.data.status == 'novo'
        && request.resource.data.nomeContato is string
        && request.resource.data.nomeContato.size() > 2
        && request.resource.data.nomeContato.size() < 200
        && request.resource.data.telefone is string
        && request.resource.data.telefone.size() > 7
        && request.resource.data.telefone.size() < 20
        && !request.resource.data.keys().hasAny(['projectId', 'contatadoPor'])
        && request.resource.data.keys().size() <= 15;
      allow read, update, delete: if isAuthenticated();
    }

    // ── Projetos V2 ──
    match /projects_v2/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['createdAt', 'createdBy']);
      allow delete: if isAdmin();
    }

    // ── Cotações de Projeto ──
    match /project_cotacoes/{cotacaoId} {
      allow read, write: if isAuthenticated();
    }

    // ── Contratos de Projeto (leitura pública para link do cliente) ──
    match /project_contratos/{contratoId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Faturamentos (escrita apenas gestores) ──
    match /project_faturamentos/{fatId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isManager();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // GANTT COMPLETO — WBS, ADVERSIDADES, BASELINES
    // ══════════════════════════════════════════════════════════════════════

    // ── Tarefas WBS do Gantt (gestores podem editar; técnicos só leem) ──
    match /gantt_tasks/{taskId} {
      allow read: if isAuthenticated();
      // Criar: apenas gestores
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.keys().hasAll(['projectId', 'label', 'nivel', 'ordem', 'party', 'status', 'progresso', 'isCritico'])
        && request.resource.data.projectId is string
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 500;
      // Atualizar: gestores podem editar tudo exceto projectId/criadoPor/criadoEm
      allow update: if isAuthenticated() && isManager()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['projectId', 'criadoPor', 'criadoEm']);
      // Deletar: apenas gestores (também deleta subtarefas via batch no client)
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Baselines de Cronograma (snapshots imutáveis após criação) ──
    match /gantt_baselines/{baselineId} {
      allow read: if isAuthenticated();
      // Criar: gestores
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.keys().hasAll(['projectId', 'nome', 'tasks', 'criadoPor', 'criadoEm'])
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0;
      // Baselines são imutáveis (não permite update, apenas delete)
      allow update: if false;
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Regra padrão: apenas autenticados ────────────────────────────────
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
