rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Apresentações: leitura pública (link de cliente sem auth) ──
    // Permite que qualquer cliente acesse /p/{slug} sem precisar de login.
    match /presentations/{presentationId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Orçamentos Públicos: leitura pública (/orcamentos/:id) ──
    match /os_orcamentos/{orcamentoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Regra padrão: apenas autenticados ──
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
