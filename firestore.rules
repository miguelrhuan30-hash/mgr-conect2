rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções helper ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isAdmin() {
      return request.auth.token.role == 'admin';
    }
    function isManager() {
      return request.auth.token.role == 'manager'
          || request.auth.token.role == 'admin';
    }
    // Portal do Cliente — role lido do doc Firestore (não custom claim, igual
    // ao padrão já usado por isIntelAuthorized() mais abaixo). Usuário externo
    // à MGR, precisa ser excluído do acesso amplo dado a "qualquer autenticado".
    function isCliente() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'cliente';
    }
    function clientCannotElevateBiometric() {
      let d = request.resource.data;
      return d.biometricVerified == false
          && d.processingStatus == 'pending'
          && d.photoURL == null
          && d.aiValidation == null;
    }
    function hasRequiredPontoFields() {
      let d = request.resource.data;
      return d.keys().hasAll([
        'userId','type','timestamp','isManual',
        'biometricVerified','processingStatus'
      ]);
    }
    function isValidPontoType() {
      return request.resource.data.type in [
        'entry','lunch_start','lunch_end','exit'
      ];
    }

    // ── Apresentações: leitura pública (link de cliente sem auth) ──
    match /presentations/{presentationId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── Orçamentos Públicos: leitura pública (/orcamentos/:id) ──
    match /os_orcamentos/{orcamentoId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── Registro de Ponto ─────────────────────────────────────────────────
    match /timeEntries/{entryId} {
      allow read: if isAuthenticated()
        && (isOwner(resource.data.userId) || isManager());
      // Colaborador criando seu próprio ponto
      allow create: if isAuthenticated()
        && (
          // Próprio colaborador
          (isOwner(request.resource.data.userId)
            && hasRequiredPontoFields()
            && isValidPontoType()
            && clientCannotElevateBiometric())
          ||
          // Gestor/Admin fazendo correção manual para outro colaborador
          (isManager()
            && hasRequiredPontoFields()
            && isValidPontoType())
        );
      allow update: if isAuthenticated()
        && (
          // Próprio ponto: atualização restrita a campos de processamento
          (isOwner(resource.data.userId)
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['photoURL', 'aiValidation',
                         'biometricVerified', 'processingStatus']))
          ||
          // Gestor/Admin: pode editar qualquer campo
          isManager()
        );
      allow delete: if isAdmin();
    }

    // ── Locais de Trabalho ────────────────────────────────────────────────
    match /workLocations/{locationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Usuários ──────────────────────────────────────────────────────────
    match /users/{userId} {
      // Leitura ampla pra equipe interna: técnico precisa listar gestores pra
      // notificar dúvidas de Suporte, reatribuição de O.S. e outros fluxos já
      // existentes. Cliente do Portal (role externo à MGR) só lê o próprio doc.
      allow read: if isAuthenticated() && (isOwner(userId) || !isCliente());
      allow write: if isAuthenticated()
        && (isOwner(userId) || isAdmin());
    }

    // ── Tarefas / OS ──────────────────────────────────────────────────────
    match /tasks/{taskId} {
      // OS sem responsável são visíveis a qualquer técnico autenticado
      allow read: if isAuthenticated()
        && (
          resource.data.get('assignedTo', null) == null
          || resource.data.get('assignedTo', '') == ''
          || resource.data.assignedTo == request.auth.uid
          || request.auth.uid in resource.data.get('assignedUsers', [])
          || isManager()
        );

      // Gestores: escrita total
      allow update, delete: if isManager();

      // Técnicos: podem atualizar status das próprias OS e pegar OS sem responsável
      allow update: if isAuthenticated() && !isManager() && (
        // Pegar OS sem responsável (atribui a si e inicia)
        (
          (resource.data.get('assignedTo', null) == null || resource.data.get('assignedTo', '') == '')
          && request.resource.data.assignedTo == request.auth.uid
        )
        ||
        // Atualizar status das próprias OS (ex: in-progress → completed)
        (
          resource.data.assignedTo == request.auth.uid
          || request.auth.uid in resource.data.get('assignedUsers', [])
        )
      );

      // Criar OS: gestores ou qualquer autenticado com permissão (validada no app)
      allow create: if isAuthenticated() && (
        isManager()
        || (
          request.resource.data.get('startDate', null) == null
          && request.resource.data.status == 'pending'
          && request.resource.data.criadoPor == request.auth.uid
          && request.resource.data.keys().hasAll(['title', 'status', 'criadoPor', 'criadoEm'])
        )
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // MÓDULO DE PROJETOS V2 — SECURITY RULES
    // ══════════════════════════════════════════════════════════════════════

    // ── Candidatos: criação pública pelo site Trabalhe Conosco ──
    match /candidatos/{candidatoId} {
      allow create: if
        request.resource.data.keys().hasAll([
          'nomeCompleto', 'email', 'telefone', 'cidade',
          'areaInteresse', 'nivelExperiencia', 'criadoEm', 'status'
        ])
        && request.resource.data.status == 'novo'
        && request.resource.data.nomeCompleto is string
        && request.resource.data.nomeCompleto.size() > 2
        && request.resource.data.nomeCompleto.size() < 200
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.email.size() < 200
        && request.resource.data.telefone is string
        && request.resource.data.telefone.size() > 7
        && request.resource.data.telefone.size() < 30
        && request.resource.data.keys().size() <= 16;
      // Gestores autenticados leem, atualizam (mover status) e podem deletar
      allow read, update: if isAuthenticated() && isManager();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Leads: criação pública com validação (formulário anúncios) ──
    match /project_leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll([
          'nomeContato', 'telefone', 'tipoProjetoSlug', 'criadoEm', 'status'
        ])
        && request.resource.data.status == 'novo'
        && request.resource.data.nomeContato is string
        && request.resource.data.nomeContato.size() > 2
        && request.resource.data.nomeContato.size() < 200
        && request.resource.data.telefone is string
        && request.resource.data.telefone.size() > 7
        && request.resource.data.telefone.size() < 20
        && !request.resource.data.keys().hasAny(['projectId', 'contatadoPor'])
        && request.resource.data.keys().size() <= 15;
      // Gestores podem criar leads manualmente (origem: 'manual') pelo painel
      allow create: if isAuthenticated() && isManager();
      // Gestores podem mover leads no funil, salvar notas e converter
      allow update: if isAuthenticated() && isManager();
      allow read, delete: if isAuthenticated();
    }

    // ── Configurações do sistema (leads_config, futuras configs) ──
    match /configs/{configId} {
      // Qualquer autenticado pode LER (Function precisa buscar o e-mail)
      allow read: if isAuthenticated();
      // Somente admin pode ESCREVER (protege e-mail e configurações sensíveis)
      allow write: if isAdmin();
    }

    // ── Projetos V2 ──
    match /projects_v2/{projectId} {
      // Leitura autenticada (sistema interno)
      allow read: if isAuthenticated();

      // Leitura pública: proposta com slug publicado (link enviado ao cliente)
      allow read: if resource.data.get('propostaDocumento', null) != null
                   && resource.data.propostaDocumento.get('slug', null) != null;

      allow create: if isAuthenticated();

      // Atualização autenticada (sistema interno)
      allow update: if isAuthenticated()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['createdAt', 'createdBy']);

      // Aceite/assinatura público: cliente sem login registra aprovação e/ou assinatura.
      // Fluxo: publicado → aceito → assinado. Bloqueado se já assinado.
      allow update: if resource.data.get('propostaDocumento', null) != null
        && resource.data.propostaDocumento.get('slug', null) != null
        && resource.data.propostaDocumento.get('status', '') != 'assinado'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['propostaDocumento'])
        && request.resource.data.propostaDocumento.diff(resource.data.propostaDocumento)
            .affectedKeys().hasOnly([
              'status',
              'aceitoEm', 'aceitoPor', 'aceitoPorEmail',
              'assinadoEm',
              'assinaturaDesenho',
              'contratoFinalUrl', 'contratoFinalPath',
              'contratoAssinadoUrls'
            ]);

      allow delete: if isAdmin();
    }

    // ── Cotações de Projeto ──
    match /project_cotacoes/{cotacaoId} {
      allow read, write: if isAuthenticated();
    }

    // ── Contratos de Projeto (leitura pública para link do cliente) ──
    match /project_contratos/{contratoId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Faturamentos (escrita apenas gestores) ──
    match /project_faturamentos/{fatId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isManager();
      allow delete: if isAdmin();
    }

    // ── Contratos de Manutenção SLA (Fase 1 — só equipe interna) ──
    match /contratos_sla/{contratoId} {
      // Equipe interna lê tudo; cliente do Portal só lê o(s) contrato(s) do próprio clientId.
      allow read: if isAuthenticated() && (!isCliente() ||
        resource.data.clientId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId);
      allow create, update: if isAuthenticated() && isManager();
      allow delete: if isAdmin();
    }

    // ── Chamados de Contrato SLA (Portal do Cliente) ──
    match /chamados_sla/{chamadoId} {
      allow read: if isAuthenticated() && (isManager() ||
        (isCliente() && resource.data.clientId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId));
      allow create: if isAuthenticated() && isCliente()
        && request.resource.data.clientId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId
        && request.resource.data.criadoPorUid == request.auth.uid;
      allow update: if isAuthenticated() && isManager();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // GANTT COMPLETO — WBS, ADVERSIDADES, BASELINES
    // ══════════════════════════════════════════════════════════════════════

    // ── Tarefas WBS do Gantt (gestores podem editar; técnicos só leem) ──
    match /gantt_tasks/{taskId} {
      allow read: if isAuthenticated();
      // Criar: apenas gestores
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.keys().hasAll(['projectId', 'label', 'nivel', 'ordem', 'party', 'status', 'progresso', 'isCritico'])
        && request.resource.data.projectId is string
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 500;
      // Atualizar: gestores podem editar tudo exceto projectId/criadoPor/criadoEm
      allow update: if isAuthenticated() && isManager()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['projectId', 'criadoPor', 'criadoEm']);
      // Deletar: apenas gestores (também deleta subtarefas via batch no client)
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Baselines de Cronograma (snapshots imutáveis após criação) ──
    match /gantt_baselines/{baselineId} {
      allow read: if isAuthenticated();
      // Criar: gestores
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.keys().hasAll(['projectId', 'nome', 'tasks', 'criadoPor', 'criadoEm'])
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0;
      // Baselines são imutáveis (não permite update, apenas delete)
      allow update: if false;
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Intel Workspace v2 (Sprint IW-01) ────────────────────────────────────
    function isIntelAuthorized() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role in ['admin', 'developer', 'intel_admin', 'intel_analyst', 'intel_viewer'];
    }
    function isIntelReadOnly() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'intel_viewer';
    }

    match /intel_items/{itemId} {
      allow read: if isAuthenticated() && isIntelAuthorized();
      allow create: if isAuthenticated() && isIntelAuthorized() && !isIntelReadOnly()
        && request.resource.data.text.size() <= 500
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isIntelAuthorized() && !isIntelReadOnly()
        && request.resource.data.text.size() <= 500;
      allow delete: if isAuthenticated() && isIntelAuthorized() && !isIntelReadOnly();
    }

    match /intel_links/{linkId} {
      allow read: if isAuthenticated() && isIntelAuthorized();
      allow create: if isAuthenticated() && isIntelAuthorized() && !isIntelReadOnly()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if false; // Links são imutáveis — delete e recrie
      allow delete: if isAuthenticated() && isIntelAuthorized() && !isIntelReadOnly();
    }

    match /intel_tool_state/{toolId} {
      allow read: if isAuthenticated() && isIntelAuthorized();
      allow write: if isAuthenticated() && isIntelAuthorized() && !isIntelReadOnly()
        && toolId in ['eisenhower', 'ishikawa', 'canvas', 'bpmn', 'roadmap'];
    }

    // ── Sprint IW-02: Multi-Análise Ishikawa ─────────────────────────────────
    match /hub_ishikawa_analyses/{analysisId} {
      allow read: if isAuthenticated() && isIntelAuthorized();
      allow create: if isAuthenticated()
        && isIntelAuthorized()
        && !isIntelReadOnly()
        && request.resource.data.nome is string
        && request.resource.data.nome.size() >= 3
        && request.resource.data.nome.size() <= 120
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.deleted == false;
      allow update: if isAuthenticated()
        && isIntelAuthorized()
        && !isIntelReadOnly()
        && !request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasAny(['createdBy', 'createdAt', 'createdByName']);
      allow delete: if false;
    }

    // ── Sprint 52 — Pesquisas Públicas Anônimas ────────────────────────────
    // Surveys com linkPublico=true são acessíveis sem autenticação
    match /surveys/{surveyId} {
      allow read: if resource.data.get('linkPublico', false) == true
                   && resource.data.status == 'ativo';
      // autenticados (catch-all cobre, mas regra explícita aqui para clareza)
      allow read, write: if isAuthenticated();
    }

    // Chaves de acesso: leitura pública (para validar), update público restrito
    match /survey_access_keys/{keyId} {
      // Qualquer um pode ler para validar a chave
      allow read: if true;
      // Criação somente por autenticados (admin gerando chaves)
      allow create: if isAuthenticated();
      // Update público: apenas marcar como usado (usado=true, usadoEm)
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['usado', 'usadoEm'])
                    && request.resource.data.usado == true
                    && resource.data.usado == false;
      allow delete: if isAuthenticated();
    }

    // Respostas: criação pública para pesquisas anônimas
    match /survey_responses/{responseId} {
      allow create: if request.resource.data.keys().hasAll(['surveyId', 'respostas', 'respondidoEm'])
                    && request.resource.data.surveyId is string
                    && !request.resource.data.keys().hasAny(['userId'])
                    && request.resource.data.keys().size() <= 5;
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── Link /card — contador de acessos via QR code do cartão de visita ──
    match /card_accesses/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['timestamp', 'campaign', 'redirectTarget'])
        && request.resource.data.campaign is string
        && request.resource.data.campaign.size() > 0
        && request.resource.data.campaign.size() <= 50
        && request.resource.data.redirectTarget is string
        && request.resource.data.keys().size() <= 6;
      allow read: if isAuthenticated() && isManager();
    }

    // ── Sprint Academy — Certificações NR ────────────────────────────────
    match /employee_certifications/{certId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.keys().hasAll(['colaboradorId', 'tipo', 'nome', 'dataObtencao', 'registradoPor', 'registradoEm', 'status'])
        && request.resource.data.colaboradorId is string
        && request.resource.data.tipo is string
        && request.resource.data.nome is string;
      allow update: if isAuthenticated() && isManager();
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Sprint Academy — Vistorias de Supervisão ─────────────────────────
    match /supervision_vistorias/{vistoriaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.keys().hasAll(['colaboradorId', 'dataVistoria', 'realizadaPor', 'itensVerificados', 'criadoEm'])
        && request.resource.data.colaboradorId is string
        && request.resource.data.realizadaPor == request.auth.uid;
      allow update: if isAuthenticated() && isManager();
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Pedidos de Redefinição de Senha ──────────────────────────────────
    // Qualquer um pode criar (tela de login sem autenticação)
    // Somente gestores autenticados podem ler e atualizar
    match /password_reset_requests/{requestId} {
      allow create: if
        request.resource.data.keys().hasAll(['email', 'status', 'requestedAt'])
        && request.resource.data.status == 'pending'
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.email.size() < 200
        && request.resource.data.keys().size() <= 8;
      allow read, update: if isAuthenticated() && isManager();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // MGR ACADEMY — LMS interno (módulos, questões, progresso, provas, badges)
    // ══════════════════════════════════════════════════════════════════════

    // ── Módulos: colaborador lê apenas publicados; rascunho só gestor ──
    match /academy_modules/{moduleId} {
      allow read: if isAuthenticated()
        && (resource.data.get('status', 'draft') == 'published' || isManager());
      allow create, update, delete: if isAuthenticated() && isManager();
    }

    // ── Banco de questões: escrita só gestor. ────────────────────────────
    // ⚠️ Fase 3: o gabarito (correctIndex) é servido ao colaborador SEM a
    //    resposta via Cloud Function `startExam`. A correção roda na Function
    //    (Admin SDK). A leitura direta deve ser bloqueada endurecendo o
    //    catch-all final nesta fase. Por ora só gestor lê/escreve aqui.
    match /academy_questions/{questionId} {
      allow read: if isAuthenticated() && isManager();
      allow create, update, delete: if isAuthenticated() && isManager();
    }

    // ── Progresso: colaborador escreve só o próprio doc de conteúdo ──
    match /academy_progress/{progressId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isManager());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      // Colaborador atualiza só campos de progresso de conteúdo;
      // badge/score/examBlocked ficam para Cloud Function / gestor.
      allow update: if isAuthenticated()
        && (
          (resource.data.userId == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['badge', 'score', 'scorePercent', 'examBlocked', 'completedAt']))
          || isManager()
        );
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Tentativas de prova: colaborador cria/lê as próprias ──
    // score/badge são gravados pela Cloud Function (Admin SDK ignora estas regras).
    match /academy_exam_attempts/{attemptId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isManager());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isManager());
      allow delete: if isAuthenticated() && isManager();
    }

    // ── Badges externos / certificações: cadastro manual pelo gestor ──
    match /academy_external_badges/{badgeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isManager();
    }

    // ── Feed de Gestão — Atividades em tempo real ────────────────────────
    match /activity_feed/{activityId} {
      // Qualquer colaborador autenticado cria atividades (ponto, OS, veículo)
      allow create: if isAuthenticated()
        && request.resource.data.autorId == request.auth.uid
        && request.resource.data.keys().hasAll(['tipo', 'autorId', 'autorNome', 'titulo', 'criadoEm']);
      // Leitura: apenas gestores veem o feed completo
      allow read: if isAuthenticated() && isManager();
      // Update: gestores atualizam (ex: respondida, respostasCount)
      allow update: if isAuthenticated() && isManager();
      // Delete: apenas admin
      allow delete: if isAdmin();
    }

    // Subcoleção de respostas a dúvidas técnicas
    match /activity_feed/{activityId}/respostas/{replyId} {
      // Gestores criam respostas
      allow create: if isAuthenticated() && isManager()
        && request.resource.data.autorId == request.auth.uid;
      // Leitura: gestores ou dono da atividade (técnico que abriu a dúvida)
      allow read: if isAuthenticated() && (
        isManager()
        || get(/databases/$(database)/documents/activity_feed/$(activityId)).data.autorId == request.auth.uid
      );
      allow update, delete: if isAuthenticated() && isManager();
    }

    // ── Regra padrão: apenas autenticados ────────────────────────────────
    // Fallback pra coleções internas sem regra própria — exclui explicitamente
    // o Portal do Cliente (role externo à MGR não deve herdar acesso amplo só
    // por estar autenticado; precisa de regra própria e restrita por coleção).
    match /{document=**} {
      allow read, write: if isAuthenticated() && !isCliente();
    }
  }
}
