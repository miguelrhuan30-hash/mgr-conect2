rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Apresentações: leitura pública, upload restrito a autenticados ──
    // Leitura pública permite que clientes acessem o PDF sem autenticação
    match /presentations/{slug}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 20 * 1024 * 1024; // max 20MB
    }

    // ── PDFs de Orçamentos: leitura pública (link compartilhável) ──
    match /orcamentos/{orcamentoId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 30 * 1024 * 1024; // max 30MB
    }

    // ── Contratos de Projeto: leitura pública (cliente sem login baixa para assinar) ──
    //   projects/{projectId}/contrato.pdf            → contrato original (admin sobe)
    //   projects/{projectId}/contrato_final.pdf      → contrato carimbado pós-assinatura virtual (cliente público sobe)
    //   projects/{projectId}/contrato_assinado/...   → uploads de contrato impresso assinado (cliente ou admin)
    match /projects/{projectId}/contrato.pdf {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 30 * 1024 * 1024;
    }
    match /projects/{projectId}/contrato_final.pdf {
      allow read: if true;
      allow write: if request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 30 * 1024 * 1024;
    }
    match /projects/{projectId}/contrato_assinado/{fileName} {
      allow read: if true;
      allow write: if request.resource.size <= 20 * 1024 * 1024
                   && (
                     request.resource.contentType == 'application/pdf'
                     || request.resource.contentType.matches('image/.*')
                   );
    }

    // ── Apresentação da Proposta (Passo 1): leitura pública (link do cliente) ──
    //   projects/{projectId}/apresentacao.pdf         → apresentação em PDF
    //   projects/{projectId}/apresentacao.html        → apresentação em HTML
    //   projects/{projectId}/proposta_descritiva.pdf  → descritivo técnico em PDF
    match /projects/{projectId}/apresentacao.pdf {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 30 * 1024 * 1024;
    }
    match /projects/{projectId}/apresentacao.html {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'text/html'
                   && request.resource.size <= 30 * 1024 * 1024;
    }
    match /projects/{projectId}/proposta_descritiva.pdf {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 30 * 1024 * 1024;
    }

    // ── Currículos de candidatos: upload público pelo site Trabalhe Conosco ──
    // Leitura restrita (link com token usado pelo gestor no banco de candidatos)
    match /candidatos/{candidatoId}/{fileName} {
      allow read: if true;
      allow create: if request.resource.size <= 5 * 1024 * 1024 // max 5MB
                    && request.resource.contentType.matches('application/.*');
      allow delete: if request.auth != null;
    }

    // ── APK do app de campo: download público (link de instalação) ──
    match /apk/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── MGR Academy: conteúdo dos módulos (PDF, vídeo, infográfico, capa) ──
    //   academy/{moduleId}/conteudo.pdf
    //   academy/{moduleId}/video.mp4
    //   academy/{moduleId}/infografico.(png|jpg|webp)
    //   academy/{moduleId}/capa.(png|jpg|webp)
    //   academy/external/{userId}/{fileName}  → comprovantes de cursos externos
    match /academy/{moduleId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 200 * 1024 * 1024 // max 200MB (vídeo)
                   && (
                     request.resource.contentType == 'application/pdf'
                     || request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('video/.*')
                   );
    }
    match /academy/external/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 20 * 1024 * 1024
                   && (
                     request.resource.contentType == 'application/pdf'
                     || request.resource.contentType.matches('image/.*')
                   );
    }

    // ── Regra genérica: somente autenticados podem ler/escrever ──
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
