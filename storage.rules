rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Regras padrão: somente autenticados podem ler/escrever ──
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── PDFs de Orçamentos: leitura pública (link compartilhável) ──
    // Upload apenas por usuários autenticados
    // Leitura por qualquer pessoa com o link (clientes externos)
    match /orcamentos/{orcamentoId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size <= 30 * 1024 * 1024; // max 30MB
    }
  }
}
